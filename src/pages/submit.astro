---
export const prerender = false;

import Layout from "../layouts/Layout.astro";

const US_STATES: [string, string][] = [
  ["AL","Alabama"],["AK","Alaska"],["AZ","Arizona"],["AR","Arkansas"],["CA","California"],
  ["CO","Colorado"],["CT","Connecticut"],["DE","Delaware"],["FL","Florida"],["GA","Georgia"],
  ["HI","Hawaii"],["ID","Idaho"],["IL","Illinois"],["IN","Indiana"],["IA","Iowa"],
  ["KS","Kansas"],["KY","Kentucky"],["LA","Louisiana"],["ME","Maine"],["MD","Maryland"],
  ["MA","Massachusetts"],["MI","Michigan"],["MN","Minnesota"],["MS","Mississippi"],["MO","Missouri"],
  ["MT","Montana"],["NE","Nebraska"],["NV","Nevada"],["NH","New Hampshire"],["NJ","New Jersey"],
  ["NM","New Mexico"],["NY","New York"],["NC","North Carolina"],["ND","North Dakota"],["OH","Ohio"],
  ["OK","Oklahoma"],["OR","Oregon"],["PA","Pennsylvania"],["RI","Rhode Island"],["SC","South Carolina"],
  ["SD","South Dakota"],["TN","Tennessee"],["TX","Texas"],["UT","Utah"],["VT","Vermont"],
  ["VA","Virginia"],["WA","Washington"],["WV","West Virginia"],["WI","Wisconsin"],["WY","Wyoming"],
];

const title = "Submit a Bingo Hall";
const description = "Submit a new bingo hall to BingoFinder. All listings are reviewed before going live.";
---

<Layout title={title} description={description}>
  <main class="max-w-2xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:underline">Home</a> &rsaquo;{" "}
      <span class="text-gray-900">Submit a Listing</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">Submit a Bingo Hall</h1>
    <p class="text-gray-600 mb-8">
      Know a bingo hall that&apos;s not listed? Submit it here. All submissions are reviewed before going live.
    </p>

    <div id="success-banner" hidden class="bg-green-50 border border-green-200 rounded-xl p-5 mb-8">
      <h2 class="font-semibold text-green-900 mb-1">Submission received!</h2>
      <p class="text-green-800 text-sm">
        Thanks for contributing. Your listing will be reviewed and published within 2–3 business days.
      </p>
      <button
        id="submit-another"
        type="button"
        class="mt-3 text-sm text-green-700 underline"
      >
        Submit another listing
      </button>
    </div>

    <form id="hall-form" class="space-y-5">
      {/* Hall info */}
      <div class="bg-gray-50 rounded-xl p-5 space-y-4">
        <h2 class="font-semibold text-gray-900">Hall Information</h2>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Hall Name <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            name="name"
            required
            maxlength="200"
            placeholder="e.g. VFW Post 1234 Bingo"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Street Address <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            name="address"
            required
            maxlength="300"
            placeholder="e.g. 123 Main St"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
          />
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              City <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              name="city"
              required
              maxlength="100"
              placeholder="e.g. Springfield"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              State <span class="text-red-500">*</span>
            </label>
            <select
              name="state"
              required
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500 bg-white"
            >
              <option value="">Select…</option>
              {US_STATES.map(([abbr, name]) => (
                <option value={abbr}>{abbr} — {name}</option>
              ))}
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              ZIP Code <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              name="zip"
              required
              maxlength="10"
              pattern="\d{5}(-\d{4})?"
              placeholder="e.g. 90210"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
            <input
              type="tel"
              name="phone"
              maxlength="20"
              placeholder="e.g. (555) 123-4567"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
            />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Bingo Hours</label>
          <input
            type="text"
            name="hours"
            maxlength="200"
            placeholder="e.g. Fri 6pm, Sat 2pm & 6pm"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Website</label>
          <input
            type="url"
            name="website"
            maxlength="300"
            placeholder="https://..."
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
          />
        </div>
      </div>

      {/* Submitter info */}
      <div class="bg-gray-50 rounded-xl p-5 space-y-4">
        <h2 class="font-semibold text-gray-900">
          Your Information <span class="text-xs text-gray-500 font-normal">(optional)</span>
        </h2>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
            <input
              type="text"
              name="submitterName"
              maxlength="100"
              placeholder="Jane Doe"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Your Email</label>
            <input
              type="email"
              name="submitterEmail"
              maxlength="200"
              placeholder="jane@example.com"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-purple-500"
            />
          </div>
        </div>
      </div>

      <div id="error-banner" hidden class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-red-800 text-sm"></div>

      <button
        type="submit"
        id="submit-button"
        class="w-full bg-purple-800 hover:bg-purple-700 disabled:bg-purple-400 text-white font-semibold py-3 rounded-lg transition-colors"
      >
        Submit Listing
      </button>

      <p class="text-xs text-gray-500 text-center">
        All submissions are reviewed by our team before being published. We typically respond within 2–3 business days.
      </p>
    </form>
  </main>

  <script>
    const form = document.getElementById("hall-form") as HTMLFormElement | null;
    const successBanner = document.getElementById("success-banner") as HTMLElement | null;
    const errorBanner = document.getElementById("error-banner") as HTMLElement | null;
    const submitButton = document.getElementById("submit-button") as HTMLButtonElement | null;
    const submitAnother = document.getElementById("submit-another") as HTMLButtonElement | null;

    if (form && successBanner && errorBanner && submitButton) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorBanner.hidden = true;
        submitButton.disabled = true;
        submitButton.textContent = "Submitting…";

        const data = Object.fromEntries(new FormData(form));

        try {
          const res = await fetch("/api/submit", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });
          const json = await res.json().catch(() => ({}));
          if (!res.ok) {
            errorBanner.textContent = json.error ?? "Something went wrong.";
            errorBanner.hidden = false;
          } else {
            form.hidden = true;
            successBanner.hidden = false;
            form.reset();
          }
        } catch {
          errorBanner.textContent = "Network error. Please try again.";
          errorBanner.hidden = false;
        } finally {
          submitButton.disabled = false;
          submitButton.textContent = "Submit Listing";
        }
      });
    }

    if (submitAnother && form && successBanner) {
      submitAnother.addEventListener("click", () => {
        successBanner.hidden = true;
        form.hidden = false;
      });
    }
  </script>
</Layout>
