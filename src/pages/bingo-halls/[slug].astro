---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { prisma } from "../../lib/prisma";
import { STATE_NAMES, STATE_SLUGS } from "../../lib/states";

const { slug } = Astro.params;

if (!slug) {
  return new Response("Not found", { status: 404 });
}

const hall = await prisma.bingoHall.findUnique({ where: { slug } });

if (!hall || hall.status !== "active") {
  return new Response("Not found", { status: 404 });
}

const stateName = STATE_NAMES[hall.state] ?? hall.state;
const stateSlug = STATE_SLUGS[hall.state];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: hall.name,
  address: {
    "@type": "PostalAddress",
    streetAddress: hall.address,
    addressLocality: hall.city,
    addressRegion: hall.state,
    postalCode: hall.zip,
    addressCountry: "US",
  },
  telephone: hall.phone ?? undefined,
  url: hall.website ?? undefined,
  openingHours: hall.hours ?? undefined,
  geo:
    hall.lat && hall.lng
      ? {
          "@type": "GeoCoordinates",
          latitude: hall.lat,
          longitude: hall.lng,
        }
      : undefined,
};

const title = `${hall.name} — Bingo in ${hall.city}, ${hall.state}`;
const description = `${hall.name} is a bingo hall in ${hall.city}, ${stateName}. Address: ${hall.address}. ${hall.hours ? `Hours: ${hall.hours}.` : ""} ${hall.phone ? `Call: ${hall.phone}.` : ""}`;
---

<Layout title={title} description={description} canonical={`/bingo-halls/${slug}`}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="max-w-3xl mx-auto px-4 py-8">
    {/* Breadcrumb */}
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:underline">Home</a>{" "}
      &rsaquo;{" "}
      {stateSlug && (
        <>
          <a href={`/${stateSlug}`} class="hover:underline">{stateName}</a>{" "}
          &rsaquo;{" "}
          <a href={`/${stateSlug}/${hall.citySlug}`} class="hover:underline">
            {hall.city}
          </a>{" "}
          &rsaquo;{" "}
        </>
      )}
      <span class="text-gray-900">{hall.name}</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-1">{hall.name}</h1>
    <p class="text-lg text-gray-600 mb-6">
      Bingo Hall in {hall.city}, {hall.state}
    </p>

    <div class="bg-white border border-gray-200 rounded-xl divide-y divide-gray-100">
      <div class="p-5">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-3">
          Location
        </h2>
        <address class="not-italic text-gray-900">
          {hall.address}
          <br />
          {hall.city}, {hall.state} {hall.zip}
        </address>
        <a
          href={`https://maps.google.com/?q=${encodeURIComponent(`${hall.address}, ${hall.city}, ${hall.state} ${hall.zip}`)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-block text-sm text-purple-700 hover:underline"
        >
          Get Directions →
        </a>
      </div>

      {hall.phone && (
        <div class="p-5">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">
            Phone
          </h2>
          <a
            href={`tel:${hall.phone.replace(/\D/g, "")}`}
            class="text-gray-900 hover:text-purple-700"
          >
            {hall.phone}
          </a>
        </div>
      )}

      {hall.hours && (
        <div class="p-5">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">
            Hours / Schedule
          </h2>
          <p class="text-gray-900">{hall.hours}</p>
        </div>
      )}

      {hall.website && (
        <div class="p-5">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">
            Website
          </h2>
          <a
            href={hall.website}
            target="_blank"
            rel="noopener noreferrer"
            class="text-purple-700 hover:underline break-all"
          >
            {hall.website}
          </a>
        </div>
      )}

      {hall.description && (
        <div class="p-5">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">
            About
          </h2>
          <p class="text-gray-700 leading-relaxed">{hall.description}</p>
        </div>
      )}
    </div>

    {/* SEO content */}
    <section class="mt-8 bg-gray-50 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">
        About {hall.name}
      </h2>
      <p class="text-gray-600 text-sm leading-relaxed">
        {hall.name} is a bingo hall located in {hall.city}, {stateName}.{" "}
        {hall.hours && `Games are held ${hall.hours}.`} For the most current
        schedule and admission prices, call {hall.phone ?? "the venue"}{" "}
        directly. Schedules may change for holidays and special events.
      </p>
    </section>

    <div class="mt-6 text-center">
      {stateSlug && (
        <a
          href={`/${stateSlug}/${hall.citySlug}`}
          class="text-purple-700 hover:underline text-sm"
        >
          ← More bingo halls in {hall.city}, {hall.state}
        </a>
      )}
    </div>
  </main>
</Layout>
