---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { prisma } from "../../lib/prisma";
import { slugToStateName, slugToStateAbbr } from "../../lib/states";

const { state: stateSlug } = Astro.params;
const pageParam = Astro.url.searchParams.get("page");

const stateName = stateSlug ? slugToStateName(stateSlug) : null;
const stateAbbr = stateSlug ? slugToStateAbbr(stateSlug) : null;

if (!stateName || !stateAbbr) {
  return new Response("Not found", { status: 404 });
}

const allCities = await prisma.bingoHall.groupBy({
  by: ["city", "citySlug"],
  _count: { id: true },
  where: { state: stateAbbr, status: "active" },
  orderBy: { city: "asc" },
});

const totalHalls = allCities.reduce((sum, c) => sum + c._count.id, 0);

if (totalHalls === 0) {
  return new Response("Not found", { status: 404 });
}

const PAGE_SIZE = 40;
const page = Math.max(1, parseInt(pageParam ?? "1", 10) || 1);
const totalPages = Math.ceil(allCities.length / PAGE_SIZE);
const pagedCities = allCities.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);

const buildPageUrl = (p: number) => `/${stateSlug}?page=${p}`;

const title = `Bingo Halls in ${stateName}`;
const description = `Find bingo halls in ${stateName}. Browse local bingo halls by city with hours, phone numbers, and directions.`;
---

<Layout title={title} description={description} canonical={`/${stateSlug}`}>
  <main class="max-w-4xl mx-auto px-4 py-8">
    {/* Breadcrumb */}
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:underline">Home</a>{" "}
      &rsaquo; <span class="text-gray-900">{stateName}</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">
      Bingo Halls in {stateName}
    </h1>
    <p class="text-gray-600 mb-8">
      {totalHalls} bingo hall{totalHalls !== 1 ? "s" : ""} across{" "}
      {allCities.length} {allCities.length !== 1 ? "cities" : "city"} in {stateName}.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {pagedCities.map((city) => (
        <a
          href={`/${stateSlug}/${city.citySlug}`}
          class="flex items-center justify-between border border-gray-200 rounded-lg px-4 py-3 hover:border-purple-400 hover:bg-purple-50 transition-colors"
        >
          <span class="font-medium text-gray-900">{city.city}</span>
          <span class="text-sm text-gray-500 ml-2 shrink-0">
            {city._count.id} hall{city._count.id !== 1 ? "s" : ""}
          </span>
        </a>
      ))}
    </div>

    {/* Pagination */}
    {totalPages > 1 && (
      <nav class="flex items-center justify-center gap-2 mt-8">
        {page > 1 && (
          <a href={buildPageUrl(page - 1)} class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
            ← Previous
          </a>
        )}
        <span class="text-sm text-gray-600">Page {page} of {totalPages}</span>
        {page < totalPages && (
          <a href={buildPageUrl(page + 1)} class="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
            Next →
          </a>
        )}
      </nav>
    )}

    <section class="mt-12 bg-gray-50 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">
        Finding Bingo in {stateName}
      </h2>
      <p class="text-gray-600 text-sm leading-relaxed">
        {stateName} has {totalHalls} bingo halls spanning {allCities.length} cities. Many locations
        are hosted at VFW posts, American Legion halls, Eagles lodges, and Knights of Columbus chapters.
        Check individual listings for current schedules as hours may vary by season.
      </p>
      <div class="mt-4">
        <a href="/submit" class="text-purple-700 hover:underline text-sm">
          Know a hall not listed? Submit it →
        </a>
      </div>
    </section>
  </main>
</Layout>
