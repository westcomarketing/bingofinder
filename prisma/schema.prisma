generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model BingoHall {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  address         String
  city            String
  state           String
  stateSlug       String
  citySlug        String
  zip             String
  phone           String?
  hours           String?
  website         String?
  description     String?
  lat             Float?
  lng             Float?
  status          String   @default("active")
  submitterName   String?
  submitterEmail  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
